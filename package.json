{
  "name": "folia",
  "version": "0.1.1",
  "description": "Folia — a fast, private PDF editor that never uploads your files",
  "main": "./out/main/index.js",
  "author": "Ioannis Pegiadis",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder --win",
    "dist:store": "electron-vite build && electron-builder --win appx"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.460.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.8.69"
  },
  "devDependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.2",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.35.2",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.pegiadis.folia",
    "productName": "Folia",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://folia.duckdns.org/updates/"
      }
    ],
    "fileAssociations": [
      {
        "ext": "pdf",
        "name": "PDF Document",
        "description": "PDF Document",
        "role": "Editor",
        "icon": "build/icon.ico"
      }
    ],
    "appx": {
      "identityName": "PegiadisIoannis.Folia-PDF",
      "publisher": "CN=D39C3EBC-47BC-4A40-9069-2FDAFFB56AAB",
      "publisherDisplayName": "Pegiadis Ioannis",
      "applicationId": "FoliaPDF",
      "displayName": "Folia-PDF",
      "backgroundColor": "#2563EB",
      "showNameOnTiles": true,
      "languages": [
        "en-US"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Folia"
    }
  }
}
